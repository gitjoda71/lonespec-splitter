# Gmail Drafting Configuration
# Kopiera denna fil till gmail_config.yaml och fyll i dina värden.
# VIKTIGT: gmail_config.yaml ligger i .gitignore — checka aldrig in den.

# Aktivera Gmail-drafting
enabled: true

# Din Google Workspace-domän (t.ex. "company.se")
workspace_domain: "ditt-foretag.se"

# Din egen Gmail-adress i Workspace.
# Service Account impersonerar denna användare via Domain-Wide Delegation,
# så att utkasten hamnar i DENNA användares Gmail → Utkast-mapp.
delegated_user: "joel@ditt-foretag.se"

# Sökväg till service account JSON-nyckel (laddas ner från Google Cloud Console)
# Absolut väg eller relativ till denna config-fil.
service_account_key_path: "./service_account_key.json"
